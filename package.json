{
    "name": "obsidian-prettier",
    "version": "1.0.3",
    "description": "Format vault contents using Prettier.",
    "author": "Jason Heddings",
    "license": "MIT",
    "main": "main.js",
    "scripts": {
        "prepare": "husky",
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
    },
    "keywords": [
        "obsidian",
        "plugin"
    ],
    "devDependencies": {
        "@types/node": "^24.12.2",
        "@typescript-eslint/eslint-plugin": "8.57.2",
        "@typescript-eslint/parser": "8.57.2",
        "builtin-modules": "5.0.0",
        "esbuild": "0.27.4",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "obsidian": "latest",
        "prettier": "^3.8.1",
        "tslib": "2.8.1",
        "typescript": "6.0.2"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,css,scss,md}": [
            "prettier --check",
            "eslint"
        ]
    },
    "dependencies": {
        "obskit": "^1.5.0"
    }
}
